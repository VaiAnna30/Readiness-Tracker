{
  "manifest_version": 3,
  "name": "Company Readiness Tracker",
  "version": "1.0",
  "description": "Estimate your readiness for top tech companies.",
  
  "permissions": [
    "storage", 
    "sidePanel" 
  ],

  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.leetcode.com/*"
  ],
  
  "side_panel": {
    "default_path": "index.html"
  },
  
  "background": {
    "service_worker": "background.js"
  }
}